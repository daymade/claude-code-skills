    },
    "claude_command_history": {
      "path": "transcripts/history.jsonl"
    },
    "codex_transcripts": {},
    "manual_exports": [
      "transcripts/codex_history.jsonl"
    ]
  },
  "redaction": {
    "allowlisted_placeholders": [
      "sk-example-*",
      "sk-test-*"
    ],
    "extra_patterns": []
  },
  "partitioning": {
    "chunk_tokens": 2000,
    "encoding_model": "cl100k_base"
  },
  "mining_agents": [
    "patterns",
    "war-stories",
    "query-guide",
    "usage-patterns",
    "code-assets"
  ]
