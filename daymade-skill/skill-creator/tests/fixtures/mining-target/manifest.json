{
  "version": "1.0",
  "target_skill": "mining-target",
  "topic_spec": {
    "description": "Fictional ExampleHub synchronization and validation",
    "keywords": [
      "examplehub",
      "cache-first",
      "resource_id",
      "sync"
    ],
    "exclude_keywords": [
      "weather",
