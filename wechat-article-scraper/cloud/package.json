{
  "name": "wechat-scraper-cloud",
  "version": "1.0.0",
  "description": "WeChat Article Scraper - Cloud Deployment",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "deploy": "vercel --prod",
